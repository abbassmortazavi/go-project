<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Document</title>
</head>
<body>
<h1>Home Page</h1>
<ul>
    {{range .}}
        {{template "content" .}}
    {{end}}
</ul>
{{ define "content"}}
<li><b>{{.Title}}</b>{{.Content}}</li>
{{end}}
</body>
</html>

